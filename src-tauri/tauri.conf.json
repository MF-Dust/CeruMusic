{
  "productName": "CeruMusic",
  "version": "1.14.1",
  "identifier": "cn.shiqianjiang.cerumusic",
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Ceru Music",
        "width": 1100,
        "height": 750,
        "minWidth": 1100,
        "minHeight": 670,
        "resizable": true,
        "decorations": false,
        "url": "/"
      },
      {
        "label": "lyric-window",
        "title": "Desktop Lyric",
        "width": 800,
        "height": 180,
        "minWidth": 440,
        "minHeight": 120,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "url": "/#/desktop-lyric"
      },
      {
        "label": "recognition-worker",
        "title": "Recognition Worker",
        "visible": false,
        "url": "/#/recognition-worker"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "build": {
    "beforeDevCommand": "pnpm web:dev",
    "beforeBuildCommand": "pnpm web:build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  }
}
